general {
    disable_loading_bar = true
    grace = 0
    hide_cursor = true
    no_fade_in = false
    no_fade_out = false
    ignore_empty_input = true
}

background {
    monitor =
    path = /home/adrien/.config/hypr/wallpapers/ToriPixel.png
    blur_size = 5
    blur_passes = 2
    noise = 0.02
    contrast = 0.9
    brightness = 0.65
    vibrancy = 0.08
    vibrancy_darkness = 0.0
}

# Heure
label {
    monitor =
    text = cmd[update:1000] echo "$(date +'%H:%M')"
    color = rgba(C8D1E9ff)
    font_size = 90
    font_family = JetBrains Mono DemiBold
    shadow_passes = 3
    shadow_size = 8
    shadow_color = rgba(000000cc)
    shadow_boost = 1.2
    position = 0, 200
    halign = center
    valign = center
}

# Date
label {
    monitor =
    text = cmd[update:60000] echo "$(LC_TIME=fr_FR.UTF-8 date +'%A, %d %B')"
    color = rgba(7AAEDDff)
    font_size = 15
    font_family = JetBrains Mono DemiBold
    shadow_passes = 2
    shadow_size = 6
    shadow_color = rgba(000000cc)
    shadow_boost = 1.2
    position = 0, 108
    halign = center
    valign = center
}

# Utilisateur
label {
    monitor =
    text = $USER
    color = rgba(7AAEDDcc)
    font_size = 13
    font_family = JetBrains Mono DemiBold
    shadow_passes = 2
    shadow_size = 6
    shadow_color = rgba(000000cc)
    shadow_boost = 1.2
    position = 0, -20
    halign = center
    valign = center
}

# Météo (bas centre gauche)
label {
    monitor =
    text = cmd[update:300000] curl -s --max-time 5 "wttr.in/?format=%c+%t" 2>/dev/null || echo "─"
    color = rgba(C8D1E9cc)
    font_size = 13
    font_family = JetBrains Mono DemiBold
    shadow_passes = 2
    shadow_size = 6
    shadow_color = rgba(000000cc)
    shadow_boost = 1.2
    position = -80, 40
    halign = center
    valign = bottom
}

# Batterie (bas centre droite)
label {
    monitor =
    text = cmd[update:30000] BAT=$(cat /sys/class/power_supply/BAT0/capacity); STATUS=$(cat /sys/class/power_supply/BAT0/status); if [ "$STATUS" = "Charging" ]; then ICON="󰂄"; COLOR="DDAC26"; elif [ "$STATUS" = "Full" ]; then ICON="󰁹"; COLOR="7AAEDD"; elif [ $BAT -ge 80 ]; then ICON="󰂂"; COLOR="C8D1E9"; elif [ $BAT -ge 60 ]; then ICON="󰁿"; COLOR="C8D1E9"; elif [ $BAT -ge 40 ]; then ICON="󰁼"; COLOR="C8D1E9"; elif [ $BAT -ge 20 ]; then ICON="󰁻"; COLOR="F96565"; else ICON="󰁺"; COLOR="F96565"; fi; echo "<span foreground='##${COLOR}'>${ICON}</span> ${BAT}%"
    color = rgba(C8D1E9ff)
    font_size = 13
    font_family = JetBrains Mono DemiBold
    shadow_passes = 2
    shadow_size = 6
    shadow_color = rgba(000000cc)
    shadow_boost = 1.2
    position = 80, 40
    halign = center
    valign = bottom
}

# Champ mot de passe
input-field {
    monitor =
    size = 300, 48
    outline_thickness = 1
    dots_size = 0.2
    dots_spacing = 0.3
    dots_center = true
    dots_rounding = -1
    outer_color = rgba(C8D1E930)
    inner_color = rgba(01010Faa)
    font_color = rgba(C8D1E9ff)
    font_family = JetBrains Mono DemiBold
    fade_on_empty = true
    fade_timeout = 1200
    placeholder_text = <span foreground="##60C8D1E9"><i>mot de passe</i></span>
    hide_input = false
    rounding = 8
    check_color = rgba(7AAEDDff)
    fail_color = rgba(F96565ff)
    fail_text = <span foreground="##F96565"><i>$FAIL  ($ATTEMPTS)</i></span>
    fail_timeout = 2000
    capslock_color = rgba(F96565bb)
    position = 0, -88
    halign = center
    valign = center
}
